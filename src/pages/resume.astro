---
import Layout from '../layouts/Layout.astro';
import Header from '../components/site/Header.astro';
import { getResume } from '../lib/resume.js';

const resume = getResume();
const {
  pageTitle,
  summary,
  experience,
  skills,
  tools,
  earlyExperience,
  education,
  pdf,
  meta
} = resume;
---
<Layout title={meta.title} description={meta.description}>
  <Header />

  <main class="container wide" id="skip-header-target">
    <div class="grid grid--divider margin-y-5 gap-6">
      <section>
        <h1 class="banner-headline">{pageTitle}</h1>
      </section>

      <div class="grid grid--column-3--xl gap-5">
        <div class="grid__colspan-2--xl order-2--xl">
          <div class="medium">
            <h2 class="h3 margin-bottom-4">Relevant Experience</h2>

            <div class="grid gap-5">
              {experience.map((job, index) => (
                <section aria-labelledby={`job-title-${index}`}>
                  <div class="margin-bottom-2">
                    <h3 class="h4" id={`job-title-${index}`}>{job.title}</h3>
                    <p>
                      <strong>{job.company}</strong>
                      <span class="opacity-80" aria-label="Duration">&nbsp;&bull;&nbsp;{job.dates}</span>
                    </p>
                  </div>

                  {Array.isArray(job.description) ? (
                    <ul class="bulleted">
                      {job.description.map((item) => (
                        <li><p>{item}</p></li>
                      ))}
                    </ul>
                  ) : (
                    <p>{job.description}</p>
                  )}
                </section>
              ))}
            </div>
          </div>
        </div>

        <aside class="grid__colspan-1--xl order-1--xl">
          <div class="grid gap-4 font-size-md" style="max-width: var(--article-sidebar-width);">
            <section>
              <h2 class="h6 margin-bottom-1">Summary</h2>
              <p>{summary}</p>
            </section>

            <section>
              <h2 class="h6 margin-bottom-1">Skills</h2>
              <ul class="list-unstyled">
                {skills.map((skill) => <li>{skill}</li>)}
              </ul>
            </section>

            <section>
              <h2 class="h6 margin-bottom-1">Tools</h2>
              <ul class="list-unstyled">
                {tools.map((tool) => <li>{tool}</li>)}
              </ul>
            </section>

            <section>
              <h2 class="h6 margin-bottom-1">{earlyExperience.title}</h2>
              <p class="font-size-md">{earlyExperience.description}</p>
            </section>

            <section>
              <h2 class="h6 margin-bottom-1">Education</h2>
              <p class="margin-bottom-1">
                <strong>{education.school}</strong>
              </p>
              <p class="font-size-md">{education.credential}</p>
            </section>
          </div>
        </aside>
      </div>

      <section>
        <h2 class="screen-reader-only">Download resume (PDF)</h2>
        <div class="display-flex justify-content-end">
          <a class="button button--has-icon button--outline font-size-md" href={pdf.href} download>
            <span class="icon icon-file-download" aria-hidden="true"></span>
            <span class="button__text">{pdf.label}</span>
          </a>
        </div>
      </section>
    </div>
  </main>
</Layout>
